# ── Get Groq key FREE at console.groq.com ──────────────
GROQ_API_KEY=gsk_paste_your_key_here
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=30

# ── Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Paste the External Database URL from Render PostgreSQL ──
DATABASE_URL=postgresql://user:password@host/dbname

# ── Paste your Vercel frontend URL here (no trailing slash) ──
ALLOWED_ORIGINS=https://your-app.vercel.app

ENVIRONMENT=production
MAX_UPLOAD_SIZE_MB=20
CONFIDENCE_HITL_THRESHOLD=75
CONFIDENCE_REVIEW_THRESHOLD=90
LOG_LEVEL=INFO
